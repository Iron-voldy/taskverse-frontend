# API — backend URL (no trailing slash)
# Development: http://localhost:3001
# Production:  https://api.taskverse.app
NEXT_PUBLIC_API_URL=https://api.taskverse.app

# NextAuth
NEXTAUTH_URL=https://taskverse.app
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=<run: openssl rand -base64 32>

# Google OAuth — must match backend GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=<from Google Cloud Console>
GOOGLE_CLIENT_SECRET=<from Google Cloud Console>
